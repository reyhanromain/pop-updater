#!/usr/bin/env bash
# pop-updater — daily system + app update for Pop!_OS
# Runs as root via systemd. Do not use sudo here.

set -uo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
NC='\033[0m'

START_TIME=$(date +%s)
SUMMARY=""
TAR_APPS_CONF="/etc/pop-updater/tar-apps.conf"
TAR_APPS_DIR="/usr/local/lib/pop-updater/tar-app-scripts"

step() { echo -e "\n${CYAN}==> $1${NC}"; }
ok()   { echo -e "${GREEN}[OK]${NC} $1"; }
warn() { echo -e "${YELLOW}[SKIP]${NC} $1"; }

append() { SUMMARY="${SUMMARY}\n$1"; }

kv_get() {
    local line="$1"
    local key="$2"
    sed -n "s/.*\\b${key}=\\([^[:space:]]*\\).*/\\1/p" <<< "$line"
}

echo -e "${GREEN}"
echo "  ╔══════════════════════════════════════╗"
echo "  ║   pop-updater — $(date '+%Y-%m-%d %H:%M') WIB  ║"
echo "  ╚══════════════════════════════════════╝"
echo -e "${NC}"

# ── APT ──────────────────────────────────────────────────────────────────────
step "APT — system packages"
if command -v apt &>/dev/null; then
    apt update -qq 2>/dev/null

    UPGRADABLE=$(apt list --upgradable 2>/dev/null | grep -v "Listing..." | awk -F'[/ ]' '{print $1 "||" $3}')
    APT_LINES=""
    APT_COUNT=0

    if [[ -n "$UPGRADABLE" ]]; then
        while IFS='||' read -r pkg new_ver; do
            OLD_VER=$(dpkg-query -W -f='${Version}' "$pkg" 2>/dev/null || echo "?")
            APT_LINES="${APT_LINES}  • ${pkg}: ${OLD_VER} → ${new_ver}\n"
            ((APT_COUNT++)) || true
        done <<< "$UPGRADABLE"
    fi

    apt upgrade -y -qq 2>/dev/null && apt autoremove -y --purge -qq 2>/dev/null && apt autoclean -q 2>/dev/null
    ok "APT done"

    if [[ $APT_COUNT -gt 0 ]]; then
        append "📦 <b>APT</b> (${APT_COUNT} updated)"
        append "$APT_LINES"
    else
        append "📦 <b>APT</b> — nothing to update"
    fi
else
    warn "apt not found"
    append "📦 <b>APT</b> — not found"
fi

# ── Pop!_OS recovery ──────────────────────────────────────────────────────────
step "Pop!_OS — recovery"
if command -v pop-upgrade &>/dev/null; then
    pop-upgrade recovery upgrade from-release 2>/dev/null || true
    ok "pop-upgrade checked"
fi

# ── Firmware (fwupd) ─────────────────────────────────────────────────────────
step "Firmware — fwupdmgr"
FW_RESULT="no updates available"
if command -v fwupdmgr &>/dev/null; then
    fwupdmgr refresh --force 2>/dev/null || true
    FW_OUT=$(fwupdmgr get-updates 2>&1 || true)
    if echo "$FW_OUT" | grep -qi "no devices\|no updates\|nothing"; then
        FW_RESULT="no updates available"
    else
        fwupdmgr update -y 2>/dev/null || true
        FW_RESULT="updated"
    fi
    ok "firmware checked"
else
    FW_RESULT="fwupdmgr not found"
fi
append "🔧 <b>Firmware</b> — ${FW_RESULT}"

# ── Flatpak ───────────────────────────────────────────────────────────────────
step "Flatpak — apps"
if command -v flatpak &>/dev/null; then
    FP_BEFORE=$(flatpak remote-ls --updates 2>/dev/null | awk '{print $1 "||" $3}' || true)
    FP_LINES=""
    FP_COUNT=0

    if [[ -n "$FP_BEFORE" ]]; then
        while IFS='||' read -r app new_ver; do
            OLD_VER=$(flatpak info "$app" 2>/dev/null | awk '/Version:/{print $2}' || echo "?")
            FP_LINES="${FP_LINES}  • ${app}: ${OLD_VER} → ${new_ver}\n"
            ((FP_COUNT++)) || true
        done <<< "$FP_BEFORE"
    fi

    flatpak update -y 2>/dev/null
    flatpak uninstall --unused -y 2>/dev/null || true
    ok "Flatpak done"

    if [[ $FP_COUNT -gt 0 ]]; then
        append "📱 <b>Flatpak</b> (${FP_COUNT} updated)"
        append "$FP_LINES"
    else
        append "📱 <b>Flatpak</b> — nothing to update"
    fi
else
    warn "flatpak not found"
    append "📱 <b>Flatpak</b> — not found"
fi

# ── pip ───────────────────────────────────────────────────────────────────────
# Only touches packages the user installed themselves (--user scope).
# System/distro pip packages are managed by apt and protected by PEP 668;
# upgrading them via pip would break the OS, so we deliberately skip them.
step "pip — Python packages (user-installed only)"
ACTUAL_USER=$(logname 2>/dev/null || echo "wknd")
if id "$ACTUAL_USER" &>/dev/null && command -v pip3 &>/dev/null; then
    PIP_OUTDATED=$(sudo -u "$ACTUAL_USER" pip3 list --user --outdated --format=columns 2>/dev/null | tail -n +3)
    PIP_LINES=""
    PIP_COUNT=0

    if [[ -n "$PIP_OUTDATED" ]]; then
        while read -r pkg cur_ver latest_ver _; do
            PIP_LINES="${PIP_LINES}  • ${pkg}: ${cur_ver} → ${latest_ver}\n"
            ((PIP_COUNT++)) || true
        done <<< "$PIP_OUTDATED"
        # --break-system-packages is safe here: --user only writes to ~/.local,
        # never to system site-packages.
        echo "$PIP_OUTDATED" | awk '{print $1}' | xargs sudo -u "$ACTUAL_USER" pip3 install --user --upgrade --break-system-packages 2>&1 && ok "pip done" || echo -e "${RED}[FAIL]${NC} pip had errors"
    else
        ok "pip — nothing to update"
    fi

    if [[ $PIP_COUNT -gt 0 ]]; then
        append "🐍 <b>pip</b> (${PIP_COUNT} updated)"
        append "$PIP_LINES"
    else
        append "🐍 <b>pip</b> — nothing to update"
    fi
else
    warn "pip3 not available for user ${ACTUAL_USER}"
    append "🐍 <b>pip</b> — skipped"
fi

# ── npm global ────────────────────────────────────────────────────────────────
step "npm — global packages"
if command -v npm &>/dev/null; then
    NPM_OUTDATED=$(npm outdated -g --json 2>/dev/null || echo "{}")
    NPM_LINES=""
    NPM_COUNT=0

    if [[ "$NPM_OUTDATED" != "{}" && -n "$NPM_OUTDATED" ]]; then
        while IFS= read -r line; do
            pkg=$(echo "$line" | awk -F'"' '{print $2}')
            cur=$(echo "$NPM_OUTDATED" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('$pkg',{}).get('current','?'))" 2>/dev/null || echo "?")
            lat=$(echo "$NPM_OUTDATED" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('$pkg',{}).get('latest','?'))" 2>/dev/null || echo "?")
            NPM_LINES="${NPM_LINES}  • ${pkg}: ${cur} → ${lat}\n"
            ((NPM_COUNT++)) || true
        done < <(echo "$NPM_OUTDATED" | python3 -c "import sys,json; [print(k) for k in json.load(sys.stdin).keys()]" 2>/dev/null)
        npm update -g 2>/dev/null && ok "npm done"
    else
        ok "npm — nothing to update"
    fi

    if [[ $NPM_COUNT -gt 0 ]]; then
        append "📦 <b>npm</b> (${NPM_COUNT} updated)"
        append "$NPM_LINES"
    else
        append "📦 <b>npm</b> — nothing to update"
    fi
else
    warn "npm not found"
    append "📦 <b>npm</b> — not found"
fi

# ── Tar apps ──────────────────────────────────────────────────────────────────
step "Tar apps — standalone tarball updaters"
TAR_UPDATED_LINES=""
TAR_FAILED_LINES=""
TAR_SKIPPED_LINES=""
TAR_UPDATED_COUNT=0
TAR_CURRENT_COUNT=0
TAR_FAILED_COUNT=0
TAR_SKIPPED_COUNT=0
TAR_ENABLED_COUNT=0

if [[ -f "$TAR_APPS_CONF" ]]; then
    while IFS= read -r config_line || [[ -n "$config_line" ]]; do
        config_line="${config_line%%#*}"
        config_line="${config_line//[[:space:]]/}"
        [[ -z "$config_line" || "$config_line" != *=* ]] && continue

        app_key="${config_line%%=*}"
        app_state="${config_line#*=}"
        [[ "$app_state" != "on" ]] && continue
        ((TAR_ENABLED_COUNT++)) || true

        app_script="$TAR_APPS_DIR/$app_key"
        if [[ ! -x "$app_script" ]]; then
            warn "tar app ${app_key} script not found"
            TAR_SKIPPED_LINES="${TAR_SKIPPED_LINES}  • ${app_key}: script not found\n"
            ((TAR_SKIPPED_COUNT++)) || true
            continue
        fi

        echo "Running tar app: ${app_key}"
        TAR_OUT="$("$app_script" 2>&1)"
        TAR_RC=$?
        printf '%s\n' "$TAR_OUT"

        RESULT_LINE=$(printf '%s\n' "$TAR_OUT" | grep '^RESULT ' | tail -n 1 || true)
        if [[ -z "$RESULT_LINE" ]]; then
            TAR_FAILED_LINES="${TAR_FAILED_LINES}  • ${app_key}: no result line (exit ${TAR_RC})\n"
            ((TAR_FAILED_COUNT++)) || true
            continue
        fi

        result_app=$(kv_get "$RESULT_LINE" "app")
        result_status=$(kv_get "$RESULT_LINE" "status")
        result_old=$(kv_get "$RESULT_LINE" "old")
        result_new=$(kv_get "$RESULT_LINE" "new")
        result_message=$(kv_get "$RESULT_LINE" "message")
        result_app="${result_app:-$app_key}"
        result_message="${result_message//_/ }"

        case "$result_status" in
            updated)
                TAR_UPDATED_LINES="${TAR_UPDATED_LINES}  • ${result_app}: ${result_old:-?} → ${result_new:-?}\n"
                ((TAR_UPDATED_COUNT++)) || true
                ;;
            current)
                ((TAR_CURRENT_COUNT++)) || true
                ;;
            skipped)
                TAR_SKIPPED_LINES="${TAR_SKIPPED_LINES}  • ${result_app}: ${result_message:-skipped}\n"
                ((TAR_SKIPPED_COUNT++)) || true
                ;;
            failed|*)
                TAR_FAILED_LINES="${TAR_FAILED_LINES}  • ${result_app}: ${result_message:-failed}\n"
                ((TAR_FAILED_COUNT++)) || true
                ;;
        esac
    done < "$TAR_APPS_CONF"

    if [[ $TAR_ENABLED_COUNT -eq 0 ]]; then
        append "📦 <b>Tar apps</b> — no apps enabled"
    elif [[ $TAR_UPDATED_COUNT -gt 0 ]]; then
        append "📦 <b>Tar apps</b> (${TAR_UPDATED_COUNT} updated)"
        append "$TAR_UPDATED_LINES"
        [[ $TAR_FAILED_COUNT -gt 0 ]] && append "$TAR_FAILED_LINES"
        [[ $TAR_SKIPPED_COUNT -gt 0 ]] && append "$TAR_SKIPPED_LINES"
    elif [[ $TAR_FAILED_COUNT -gt 0 || $TAR_SKIPPED_COUNT -gt 0 ]]; then
        append "📦 <b>Tar apps</b> — issues"
        [[ $TAR_FAILED_COUNT -gt 0 ]] && append "$TAR_FAILED_LINES"
        [[ $TAR_SKIPPED_COUNT -gt 0 ]] && append "$TAR_SKIPPED_LINES"
    else
        append "📦 <b>Tar apps</b> — all up to date"
    fi
    ok "Tar apps done"
else
    warn "tar apps config not found"
    append "📦 <b>Tar apps</b> — config not found"
fi

# ── Duration ──────────────────────────────────────────────────────────────────
END_TIME=$(date +%s)
ELAPSED=$(( END_TIME - START_TIME ))
DURATION="${ELAPSED}s"
if (( ELAPSED >= 60 )); then
    DURATION="$((ELAPSED/60))m $((ELAPSED%60))s"
fi

# ── Telegram notification ────────────────────────────────────────────────────
if [[ -n "${TG_BOT_TOKEN:-}" && -n "${TG_CHAT_ID:-}" ]]; then
    HEADER="🖥️ <b>pop-updater</b> — $(date '+%Y-%m-%d %H:%M') WIB"
    FOOTER="⏱️ Duration: ${DURATION}"
    MESSAGE="${HEADER}\n\n${SUMMARY}\n${FOOTER}"

    TG_RESPONSE=$(curl -s -X POST "https://api.telegram.org/bot${TG_BOT_TOKEN}/sendMessage" \
        -H "Content-Type: application/json" \
        -d "$(jq -n \
            --arg chat_id "${TG_CHAT_ID}" \
            --arg text "$(printf '%b' "$MESSAGE")" \
            '{chat_id: $chat_id, parse_mode: "HTML", text: $text}')")

    if echo "$TG_RESPONSE" | jq -e '.ok == true' &>/dev/null; then
        ok "Telegram notification sent"
    else
        echo -e "${RED}[FAIL]${NC} Telegram error: $(echo "$TG_RESPONSE" | jq -r '.description // "unknown"')"
    fi
else
    warn "TG_BOT_TOKEN or TG_CHAT_ID not set — skipping notification"
fi

# ── Done ──────────────────────────────────────────────────────────────────────
echo -e "\n${GREEN}══════════════════════════════════════════${NC}"
echo -e "${GREEN}  All done! (${DURATION})  $(date '+%H:%M')${NC}"
echo -e "${GREEN}══════════════════════════════════════════${NC}\n"
